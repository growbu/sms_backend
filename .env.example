# ─── Server ─────────────────────────────────────────────────────────────
PORT=3002

# ─── MongoDB ─────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/sms_for_me

# ─── JWT ─────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-access-secret-change-me
JWT_REFRESH_SECRET=your-refresh-secret-change-me
JWT_ACCESS_EXPIRES_IN=365d
JWT_REFRESH_EXPIRES_IN=365d

# ─── Google OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_CALLBACK_URL=https://your-backend.vercel.app/auth/google/callback
GOOGLE_DASHBOARD_CALLBACK_URL=https://your-dashboard.com/api/google-callback

# ─── Firebase Admin (for FCM) ────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Monthly prices
STRIPE_PRICE_STARTER=price_REPLACE_ME
STRIPE_PRICE_TEAM=price_REPLACE_ME
STRIPE_PRICE_BUSINESS=price_REPLACE_ME

# Yearly prices (20% discount)
STRIPE_PRICE_STARTER_YEARLY=price_REPLACE_ME
STRIPE_PRICE_TEAM_YEARLY=price_REPLACE_ME
STRIPE_PRICE_BUSINESS_YEARLY=price_REPLACE_ME
